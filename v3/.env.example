# FinOps V3 — variáveis de ambiente para desenvolvimento local
# Copie para .env e preencha os valores

NODE_ENV=development

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google / GCP
GCP_PROJECT_ID=seu-projeto-gcp
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback
BILLING_ACCOUNT_ID=billingAccounts/XXXXXX-XXXXXX-XXXXXX

# Domínio corporativo
CORPORATE_DOMAIN=suaempresa.com.br
FRONTEND_URL=http://localhost:3000

# Huawei (em dev, deixe vazio para usar mock)
HUAWEI_AK=
HUAWEI_SK=

# Gemini
GEMINI_API_KEY=

# RAG
RAG_SIMILARITY_THRESHOLD=0.75
RAG_MAX_CHUNKS=10
RAG_MAX_TOKENS=8000

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
